<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Report Studio — Goal Prompts</title>
<meta name="description" content="Drop the reports your audits produced, check off findings, and generate a Fixer prompt that implements exactly what you picked.">
<meta property="og:title" content="Report Studio — Goal Prompts">
<meta property="og:description" content="Turn audit reports into action. Drop your report files, select findings, generate a targeted Fixer prompt.">
<meta property="og:image" content="https://goal-prompts.vercel.app/og.png">
<meta property="og:url" content="https://goal-prompts.vercel.app/studio">
<meta name="theme-color" content="#14181E">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='13' fill='%2314181E'/%3E%3Ctext x='32' y='45' font-family='monospace' font-size='32' font-weight='700' text-anchor='middle' fill='%235EE0B0'%3EGP%3C/text%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;900&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#14181E;--panel:#1B212B;--panel-2:#202834;--line:#2A3340;
    --text:#E2E6EC;--dim:#8B96A5;--faint:#5C6675;--act:#5EE0B0;--amber:#E8B44C;
    --s1:#E8705F;--s2:#E8B44C;--s3:#8B96A5;--radius:10px;
    --sans:'Archivo',system-ui,-apple-system,sans-serif;
    --mono:'IBM Plex Mono',ui-monospace,Menlo,monospace;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:var(--ink);color:var(--text);font-family:var(--sans);font-size:16px;line-height:1.5;-webkit-font-smoothing:antialiased}
  .wrap{max-width:820px;margin:0 auto;padding:0 20px}
  a{color:var(--act)}
  header{padding:48px 0 8px}
  .eyebrow{font-family:var(--mono);font-size:12px;letter-spacing:.14em;color:var(--dim);text-transform:uppercase}
  .eyebrow a{color:var(--dim);text-decoration:none}
  h1{font-weight:900;font-size:clamp(38px,8vw,64px);line-height:.95;letter-spacing:-.02em;text-transform:uppercase;margin:12px 0 14px}
  h1 .tick{color:var(--act)}
  .sub{color:var(--dim);max-width:60ch;font-size:15px}

  .drop{
    margin-top:26px;border:1.5px dashed var(--line);border-radius:var(--radius);
    background:var(--panel);padding:34px 20px;text-align:center;cursor:pointer;
    transition:border-color .15s,background .15s;
  }
  .drop:hover,.drop.over{border-color:var(--act);background:color-mix(in srgb,var(--act) 7%,var(--panel))}
  .drop h2{font-size:16px;font-weight:600;margin-bottom:4px}
  .drop p{font-size:13px;color:var(--dim);font-family:var(--mono)}
  .drop .big{font-size:26px;margin-bottom:8px}
  .samplerow{margin-top:12px;display:flex;gap:8px;justify-content:center;flex-wrap:wrap}
  .btn{
    font-family:var(--mono);font-size:12.5px;font-weight:600;cursor:pointer;
    border-radius:8px;padding:9px 13px;border:1px solid var(--line);
    background:var(--panel-2);color:var(--dim);
    -webkit-tap-highlight-color:transparent;transition:border-color .15s,color .15s;
  }
  .btn:hover{color:var(--text);border-color:var(--dim)}
  .btn.pri{background:var(--act);color:var(--ink);border-color:var(--act)}
  .btn.pri:hover{filter:brightness(1.08);color:var(--ink)}
  .btn:disabled{opacity:.4;cursor:not-allowed}

  .bar{
    position:sticky;top:0;z-index:6;margin-top:22px;
    background:linear-gradient(var(--ink) 86%,transparent);padding:10px 0;
    display:flex;align-items:center;gap:12px;flex-wrap:wrap;
  }
  .count{font-family:var(--mono);font-size:13px;color:var(--dim)}
  .count b{color:var(--act);font-weight:600}
  .bar .spacer{flex:1}
  .sev{font-family:var(--mono);font-size:11px;padding:2px 7px;border-radius:5px;border:1px solid var(--line);color:var(--dim)}

  .report{margin-top:18px}
  .rhead{
    display:flex;align-items:center;gap:10px;margin:22px 0 8px;
    font-family:var(--mono);font-size:12px;letter-spacing:.06em;color:var(--dim);
  }
  .rhead .file{color:var(--text);font-weight:600}
  .rhead .rule{flex:1;height:1px;background:var(--line)}
  .rhead .x{cursor:pointer;color:var(--faint);border:0;background:none;font-family:var(--mono);font-size:12px}
  .rhead .x:hover{color:var(--s1)}

  .finding{
    display:flex;gap:12px;background:var(--panel);border:1px solid var(--line);
    border-left:3px solid var(--sev,#8B96A5);border-radius:var(--radius);
    padding:13px 14px;margin-bottom:8px;cursor:pointer;
  }
  .finding:hover{border-color:var(--dim)}
  .finding.on{background:color-mix(in srgb,var(--act) 8%,var(--panel));border-left-color:var(--act)}
  .cb{
    flex:none;width:20px;height:20px;border-radius:5px;border:1.5px solid var(--line);
    margin-top:2px;display:grid;place-items:center;font-size:13px;color:var(--ink);
  }
  .finding.on .cb{background:var(--act);border-color:var(--act)}
  .fmeta{flex:1;min-width:0}
  .fname{font-size:14.5px;font-weight:600;line-height:1.3}
  .fsub{font-family:var(--mono);font-size:11px;color:var(--faint);margin-top:3px;display:flex;gap:10px;flex-wrap:wrap}
  .fsub .sv1{color:var(--s1)}.fsub .sv2{color:var(--s2)}
  .fbody{font-size:12.5px;color:var(--dim);margin-top:6px;line-height:1.5;white-space:pre-wrap;word-break:break-word}

  .empty{color:var(--faint);font-family:var(--mono);font-size:12.5px;padding:8px 2px}

  dialog{
    border:1px solid var(--line);border-radius:14px;background:var(--panel);
    color:var(--text);max-width:760px;width:calc(100% - 32px);padding:0;
  }
  dialog::backdrop{background:rgba(10,12,16,.7)}
  .dlg-h{display:flex;align-items:center;gap:10px;padding:16px 18px;border-bottom:1px solid var(--line)}
  .dlg-h b{font-size:15px}
  .dlg-h .spacer{flex:1}
  .dlg-b{padding:16px 18px}
  .dlg-b p{font-size:13px;color:var(--dim);margin-bottom:10px}
  pre.gen{
    font-family:var(--mono);font-size:11.5px;line-height:1.6;color:#C7CEDA;
    background:var(--ink);border:1px solid var(--line);border-radius:8px;
    padding:14px;max-height:52vh;overflow:auto;white-space:pre-wrap;word-break:break-word;
  }
  footer{border-top:1px solid var(--line);margin-top:40px;padding:26px 0 70px;color:var(--dim);font-size:13px}
  footer code{font-family:var(--mono);font-size:12px;color:var(--faint)}
  @media (prefers-reduced-motion:reduce){*{transition:none!important}}
</style>
</head>
<body>
<header class="wrap">
  <div class="eyebrow"><a href="/">← goal prompts</a> · the loop-closer</div>
  <h1>Report<br>Studio<span class="tick">.</span></h1>
  <p class="sub">Your audits wrote reports. Drop them here, check off the findings you want handled, and generate a Fixer prompt that implements exactly those — nothing retyped, nothing lost.</p>

  <div class="drop" id="drop" tabindex="0" role="button" aria-label="Drop report files or browse">
    <div class="big">📥</div>
    <h2>Drop report files here</h2>
    <p>BUGS.md, SECURITY.md, PERF.md… — or tap to browse. Parsed in your browser; nothing is uploaded.</p>
    <input type="file" id="file" accept=".md,.markdown,.txt" multiple hidden>
    <div class="samplerow">
      <button class="btn" id="loadsamples">load sample reports</button>
    </div>
  </div>
</header>

<div class="wrap">
  <div class="bar" id="bar" hidden>
    <span class="count"><b id="selcount">0</b> of <span id="totcount">0</span> findings selected</span>
    <span class="spacer"></span>
    <button class="btn" id="selall">select all</button>
    <button class="btn" id="clearall">clear</button>
    <button class="btn pri" id="gen" disabled>Generate Fixer prompt →</button>
  </div>
  <div class="report" id="reports"></div>
</div>

<dialog id="dlg">
  <div class="dlg-h">
    <b>Fixer prompt</b><span class="spacer"></span>
    <button class="btn" id="dlgcopy">copy</button>
    <button class="btn" id="dlgdl">download .md</button>
    <button class="btn" id="dlgclose">close</button>
  </div>
  <div class="dlg-b">
    <p>Paste this into Claude Code inside the repo. It carries the findings you selected and follows brief 47 · The Fixer: it asks before changing anything, then implements one finding per commit.</p>
    <pre class="gen" id="genout"></pre>
  </div>
</dialog>

<footer class="wrap">
  Studio pairs with <a href="/#47">brief 47 · The Fixer</a>. Prefer the agent do it all? Point your agent at
  <code>/raw/playbook-triagefix.md</code> — it scouts, runs what's needed, and fixes. Everything here stays on your device.
</footer>

<script>
const SAMPLES = ["BUGS.md","SECURITY.md"];
const SEVMAP = {
  s1:{c:"var(--s1)",k:"sv1",label:"S1"}, s2:{c:"var(--s2)",k:"sv2",label:"S2"},
  s3:{c:"var(--s3)",k:"",label:"S3"}, none:{c:"#8B96A5",k:"",label:""}
};
let reports = []; // {file, findings:[{name,sev,body,on}]}

/* ---- parse a report markdown into findings ----
   Handles the catalog's report shape: a "## Findings" (or Bugs/Issues/…)
   section with bold-led items, optionally numbered, each carrying a
   severity token (S1/S2/S3, critical/high/medium/low, blocker/major/minor).
   Falls back to scanning bold-led lines anywhere if no section is found. */
function detectSev(text){
  const t = text.toLowerCase();
  if(/\bs1\b|critical|blocker|data loss|\bsev(erity)?\s*1\b/.test(t)) return "s1";
  if(/\bs2\b|\bhigh\b|major|\bsev(erity)?\s*2\b/.test(t)) return "s2";
  if(/\bs3\b|medium|\blow\b|minor|nitpick/.test(t)) return "s3";
  return "none";
}
function cleanName(s){
  return s.replace(/\*\*/g,"").replace(/^#+\s*/,"").replace(/^\d+[\.\)]\s*/,"")
          .replace(/^[-*]\s*/,"").replace(/\s*[—–-].*$/,"").trim().slice(0,120);
}
function parseReport(file, text){
  const lines = text.split(/\r?\n/);
  const findings = [];
  // find a findings-ish section
  const secRe = /^#{1,4}\s+(findings|bugs|issues|vulnerabilities|opportunities|problems|gaps|recommendations)\b/i;
  let start = lines.findIndex(l => secRe.test(l));
  let scope = start >= 0 ? lines.slice(start+1) : lines;
  // stop at the next top-level section if we found a findings section
  if(start >= 0){
    const stop = scope.findIndex(l => /^#{1,2}\s+\S/.test(l) && !secRe.test(l));
    if(stop > 0) scope = scope.slice(0, stop);
  }
  let cur = null;
  const push = ()=>{ if(cur && cur.name){ cur.body = cur.body.trim(); findings.push(cur); } cur = null; };
  const itemRe = /^(#{3,4}\s+|\d+[\.\)]\s+|[-*]\s+)?\*\*(.+?)\*\*/;
  for(const raw of scope){
    const line = raw.trimEnd();
    const m = line.match(itemRe);
    // a new finding starts on a bold-led line that looks like a title (has a name, not mid-sentence)
    if(m && (/^(#{3,4}\s+|\d+[\.\)]\s+|[-*]\s+)/.test(line) || line.indexOf("**") <= 2)){
      push();
      cur = { name: cleanName(m[2] || line), sev:"none", body:"", on:false, raw:line };
      cur.sev = detectSev(line);
    } else if(cur){
      cur.body += line + "\n";
      if(cur.sev === "none") cur.sev = detectSev(line);
    }
  }
  push();
  // re-scan each finding's full text for a better severity guess
  findings.forEach(f => { if(f.sev==="none") f.sev = detectSev(f.name + " " + f.body); });
  return { file, findings };
}

/* ---- render ---- */
const reportsEl = document.getElementById("reports");
const bar = document.getElementById("bar");
function selected(){ return reports.flatMap(r => r.findings.filter(f=>f.on).map(f=>({r,f}))); }
function counts(){
  const tot = reports.reduce((n,r)=>n+r.findings.length,0);
  const sel = selected().length;
  document.getElementById("totcount").textContent = tot;
  document.getElementById("selcount").textContent = sel;
  document.getElementById("gen").disabled = sel === 0;
}
function render(){
  reportsEl.textContent = "";
  bar.hidden = reports.length === 0;
  reports.forEach((r, ri)=>{
    const head = document.createElement("div"); head.className = "rhead";
    const fl = document.createElement("span"); fl.className = "file"; fl.textContent = r.file;
    const cnt = document.createElement("span"); cnt.textContent = r.findings.length + " findings";
    const rule = document.createElement("span"); rule.className = "rule";
    const x = document.createElement("button"); x.className = "x"; x.textContent = "remove";
    x.onclick = ()=>{ reports.splice(ri,1); render(); counts(); };
    head.append(fl, cnt, rule, x);
    reportsEl.append(head);

    if(!r.findings.length){
      const e = document.createElement("div"); e.className = "empty";
      e.textContent = "No findings auto-detected. This report may use an unusual format — you can still open it in the catalog and work from brief 47 directly.";
      reportsEl.append(e); return;
    }
    r.findings.forEach(f=>{
      const sev = SEVMAP[f.sev];
      const card = document.createElement("div");
      card.className = "finding" + (f.on ? " on" : "");
      card.style.setProperty("--sev", sev.c);
      const cb = document.createElement("div"); cb.className = "cb"; cb.textContent = f.on ? "✓" : "";
      const meta = document.createElement("div"); meta.className = "fmeta";
      const nm = document.createElement("div"); nm.className = "fname"; nm.textContent = f.name;
      const sub = document.createElement("div"); sub.className = "fsub";
      if(sev.label){ const s = document.createElement("span"); s.className = sev.k; s.textContent = sev.label; sub.append(s); }
      const src = document.createElement("span"); src.textContent = r.file; sub.append(src);
      meta.append(nm, sub);
      if(f.body){ const bd = document.createElement("div"); bd.className = "fbody"; bd.textContent = f.body.slice(0,320) + (f.body.length>320?"…":""); meta.append(bd); }
      card.append(cb, meta);
      card.onclick = ()=>{ f.on = !f.on; cb.textContent = f.on?"✓":""; card.classList.toggle("on", f.on); counts(); };
      reportsEl.append(card);
    });
  });
  counts();
}

/* ---- generate the Fixer prompt ---- */
function buildFixerPrompt(items){
  const byFile = {};
  items.forEach(({r,f})=>{ (byFile[r.file] = byFile[r.file] || []).push(f); });
  let out = "# Task: implement selected audit findings\n\n";
  out += "You are working inside this repo. Below are specific findings I selected from audit reports. ";
  out += "Follow the discipline of brief 47 (The Fixer): work on a dedicated branch, confirm scope with me before changing anything, then implement one finding per commit, running the repo's checks after each. Keep each change to the smallest fix the finding names; if a fix isn't clearly safe, defer it and tell me why.\n\n";
  out += "## Findings to implement ("+items.length+")\n\n";
  let n = 1;
  for(const file in byFile){
    out += "### From "+file+"\n";
    byFile[file].forEach(f=>{
      const sev = SEVMAP[f.sev].label;
      out += "\n**"+(n++)+". "+f.name+"**"+(sev?"  ("+sev+")":"")+"\n";
      if(f.body) out += f.body.trim()+"\n";
    });
    out += "\n";
  }
  out += "## How to proceed\n";
  out += "1. Restate these findings back to me so I can confirm you understand them.\n";
  out += "2. Tell me which look safe to implement directly and which need a decision from me.\n";
  out += "3. Wait for my go-ahead on scope. Then create a branch and implement the approved findings one commit at a time.\n";
  out += "4. After each fix, run the relevant checks. If anything breaks or balloons, stop and report.\n";
  out += "5. When done, write a short FIXLOG.md and ask whether to open a PR or re-run the source audit.\n\n";
  out += "Do not change any code until I approve the scope.\n";
  return out;
}

/* ---- files ---- */
function addFiles(fileList){
  const files = [...fileList].filter(f=>/\.(md|markdown|txt)$/i.test(f.name));
  let pending = files.length;
  if(!pending) return;
  files.forEach(file=>{
    const reader = new FileReader();
    reader.onload = ()=>{
      const existing = reports.findIndex(r=>r.file===file.name);
      const parsed = parseReport(file.name, String(reader.result));
      if(existing>=0) reports[existing] = parsed; else reports.push(parsed);
      if(--pending===0) render();
    };
    reader.readAsText(file);
  });
}

const drop = document.getElementById("drop");
const fileInput = document.getElementById("file");
drop.onclick = (e)=>{ if(e.target.id!=="loadsamples") fileInput.click(); };
drop.onkeydown = (e)=>{ if(e.key==="Enter"||e.key===" ") fileInput.click(); };
fileInput.onchange = ()=>addFiles(fileInput.files);
["dragenter","dragover"].forEach(ev=>drop.addEventListener(ev,e=>{e.preventDefault();drop.classList.add("over");}));
["dragleave","drop"].forEach(ev=>drop.addEventListener(ev,e=>{e.preventDefault();drop.classList.remove("over");}));
drop.addEventListener("drop",e=>{ if(e.dataTransfer&&e.dataTransfer.files) addFiles(e.dataTransfer.files); });

document.getElementById("loadsamples").onclick = async (e)=>{
  e.stopPropagation();
  for(const name of SAMPLES){
    try{
      const res = await fetch("/"+name);
      if(res.ok){ const txt = await res.text();
        const i = reports.findIndex(r=>r.file===name);
        const p = parseReport(name, txt);
        if(i>=0) reports[i]=p; else reports.push(p);
      }
    }catch(err){}
  }
  render();
};

document.getElementById("selall").onclick = ()=>{ reports.forEach(r=>r.findings.forEach(f=>f.on=true)); render(); };
document.getElementById("clearall").onclick = ()=>{ reports.forEach(r=>r.findings.forEach(f=>f.on=false)); render(); };

const dlg = document.getElementById("dlg");
const genout = document.getElementById("genout");
document.getElementById("gen").onclick = ()=>{
  const items = selected();
  if(!items.length) return;
  genout.textContent = buildFixerPrompt(items);
  if(typeof dlg.showModal === "function") dlg.showModal(); else alert(genout.textContent);
};
document.getElementById("dlgclose").onclick = ()=>dlg.close();
document.getElementById("dlgcopy").onclick = function(){
  const t = genout.textContent;
  const done = ()=>{ this.textContent="copied ✓"; setTimeout(()=>this.textContent="copy",1500); };
  if(navigator.clipboard&&navigator.clipboard.writeText) navigator.clipboard.writeText(t).then(done).catch(fb); else fb();
  function fb(){ const ta=document.createElement("textarea"); ta.value=t; document.body.append(ta); ta.select(); try{document.execCommand("copy");done();}catch(e){} ta.remove(); }
};
document.getElementById("dlgdl").onclick = ()=>{
  const blob = new Blob([genout.textContent], {type:"text/markdown"});
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob); a.download = "fixer-prompt.md"; a.click();
  URL.revokeObjectURL(a.href);
};
</script>
</body>
</html>
