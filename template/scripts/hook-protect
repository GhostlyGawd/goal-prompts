#!/usr/bin/env python3
"""Claude Code PreToolUse hook: block edits to the harness layer.

The verification layer is operator-owned. This hook makes that a blocked
tool call (exit 2), not an instruction — the agent physically cannot weaken
the gate it is judged by. If the gate is wrong, the agent's move is to stop
and report; the fix belongs to the operator.
"""
import json
import os
import sys

PROTECTED = ("scripts/", ".githooks/", ".github/", ".claude/", "tests/harness/")


def main() -> int:
    try:
        data = json.load(sys.stdin)
    except Exception:
        return 0  # malformed input: never block blindly
    tool_input = data.get("tool_input") or {}
    path = tool_input.get("file_path") or tool_input.get("notebook_path") or ""
    if not path:
        return 0
    root = os.path.abspath(os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd())
    rel = os.path.relpath(os.path.abspath(path), root).replace(os.sep, "/")
    if any(rel == p.rstrip("/") or rel.startswith(p) for p in PROTECTED):
        print(f"BLOCKED: {rel} is the harness layer — operator-owned, "
              f"agent-read-only. If the gate itself is wrong, stop and "
              f"report it to the operator (see CLAUDE.md).", file=sys.stderr)
        return 2
    return 0


if __name__ == "__main__":
    sys.exit(main())
