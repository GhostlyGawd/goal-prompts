#!/bin/sh
# One-command gate for goal-prompts — DX.md fix 1.
#
#   scripts/check
#
# Runs everything a contribution must clear: the build (which lints every
# brief), the design gates (brand.json lint + the WCAG contrast matrix), the
# linter's and engine's own tests, the hermetic installer test, JS syntax on
# the MCP server and both site scripts, and the MCP smoke test. CI and Vercel
# run the same steps; passing here means the deploy will not surprise you.
#
# Node is required only for the mcp/ and site-script steps; prompt-only
# contributions pass with Python alone (those steps are skipped, loudly).
set -e
cd "$(dirname "$0")/.."

step=0
say() { step=$((step + 1)); printf '\n== %s/8  %s ==\n' "$step" "$1"; }

say "build (lints all briefs, regenerates every surface)"
# Capture rather than `| tail -1`: a pipe masks build.py's exit code, so a
# failing build (lint error, missing OG card) would slip past `set -e` and
# print a false "ALL CHECKS PASSED". On failure show the full output.
if ! build_out=$(python3 build.py 2>&1); then
  printf '%s\n' "$build_out"
  exit 1
fi
printf '%s\n' "$build_out" | tail -1

say "design gates (brand.json lint + WCAG contrast matrix)"
python3 design-engine/tools/brand_lint.py
python3 design-engine/tools/contrast.py

say "linter + engine tests"
python3 -m unittest discover -s tests -q
python3 -m unittest discover -s design-engine/tests -q

if command -v curl >/dev/null 2>&1; then
  say "installer (hermetic, against a local server)"
  sh scripts/test-install.sh
else
  say "installer — SKIPPED, curl not found (the installer itself needs it)"
fi

if command -v node >/dev/null 2>&1; then
  say "mcp server syntax"
  node --check mcp/server.cjs
  echo "OK  mcp/server.cjs"
  node --check sw.js
  echo "OK  sw.js"
  node --check design-engine/tools/shots.cjs
  echo "OK  design-engine/tools/shots.cjs"
  node --check design-engine/tools/motion_preview.cjs
  echo "OK  design-engine/tools/motion_preview.cjs"

  say "site script syntax (index.html + studio.html + vitals.html + coverage.html)"
  node - <<'EOF'
const fs = require("fs");
const vm = require("vm");
for (const file of ["index.html", "studio.html", "vitals.html", "coverage.html"]) {
  const html = fs.readFileSync(file, "utf8");
  const blocks = [...html.matchAll(/<script>([\s\S]*?)<\/script>/g)]
    .map(m => m[1]).filter(s => s.trim());
  if (!blocks.length) { console.error("FAIL  no inline scripts in " + file); process.exit(1); }
  blocks.forEach((src, i) => {
    try { new vm.Script(src, { filename: file + "#script" + i }); }
    catch (e) { console.error("FAIL  " + file + " script " + i + ": " + e.message); process.exit(1); }
  });
  console.log("OK  " + file + " (" + blocks.length + " script block" + (blocks.length > 1 ? "s" : "") + ")");
}
EOF

  say "site js modules (js/*.js syntax + unit tests)"
  for f in js/*.js; do
    node --check "$f"
    echo "OK  $f"
  done
  node tests/catalog_core.test.cjs
  node tests/report_parser.test.cjs
  node tests/sw_reminder.test.cjs

  say "mcp smoke (spawns the real server)"
  node scripts/mcp-smoke.cjs
else
  step=8
  printf '\n== 5-8/8  SKIPPED — node not found (needed only for mcp/ and site-script checks) ==\n'
fi

printf '\nALL CHECKS PASSED\n'
