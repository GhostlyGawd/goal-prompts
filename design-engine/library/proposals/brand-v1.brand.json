{
  "$schema": "./brand.schema.json",
  "meta": {
    "brand_version": 1,
    "note": "Brand v1 — the shipped dark terminal identity, encoded 2026-07-10 from build.py (TOKENS_CSS, FAMILY_COLORS, BRAND_MARK, FAVICON) and scripts/icons.py. Values are a faithful transcription; the only additions are the motion and elevation token groups, which nothing consumed before."
  },
  "identity": {
    "name": "goal-prompts",
    "product_name": "Goal Prompts",
    "tagline": "Turn your coding agent into a senior code auditor.",
    "voice": {
      "tone": "Senior code auditor: technical, rigorous, terminal-native, quiet confidence. Editorial, not promotional.",
      "principles": [
        "evidence not vibes",
        "show the deliverable — the → FILE.md motif states the value prop in one glyph",
        "color = family, everywhere",
        "one mark, everywhere: tab, header, home-screen, OG cards all derive from the same geometry",
        "dark, IDE-flavored, whitespace on a 4pt grid"
      ],
      "banned_words": ["revolutionary", "game-changing", "supercharge", "unleash", "blazingly"]
    },
    "signatures": [
      "the family bar motif (nav mark → hero spectrum → card border stripes → OG card bar)",
      "the → FILE.md deliverable glyph"
    ]
  },
  "palette": {
    "themes": {
      "dark": {
        "surfaces": { "ink": "#131417", "ink-2": "#0E0F11", "panel": "#1B1C20", "panel-2": "#212329" },
        "lines": { "line": "#26272C", "line-2": "#33353B", "line-3": "#45474E" },
        "text": { "text": "#F1F1F3", "dim": "#B7B8BE", "faint": "#8B8D95", "body": "#C7C8CE" },
        "controls": { "btn": "#F1F1F3", "btn-fg": "#141518", "sev": "#F0806A" },
        "accents": { "amber": "#E8B44C", "amber-2": "#F2CE7C", "fc": "#8B7CF8" },
        "semantic": { "success": "#2FAF73", "warning": "#F59E2C", "danger": "#E23B4B" },
        "aliases": { "good": "@success", "act": "@danger", "up": "@success", "down": "@danger", "meta": "#C4CBD8" }
      },
      "light": {
        "surfaces": { "ink": "#F4F3EF", "ink-2": "#EBEAE2", "panel": "#FCFBF9", "panel-2": "#EFEEE7" },
        "lines": { "line": "#E5E4DE", "line-2": "#D5D4CD", "line-3": "#BEBDB4" },
        "text": { "text": "#191A1C", "dim": "#4C4E53", "faint": "#6A6C73", "body": "#33353A" },
        "controls": { "btn": "#191A1C", "btn-fg": "#F5F4F0", "sev": "#C4402E" },
        "accents": { "amber": "#9C6E2A", "amber-2": "#B8863B", "fc": "#7C5CE0" },
        "semantic": { "success": "#1E9A5A", "warning": "#B87A12", "danger": "#C42E3E" },
        "aliases": { "good": "@success", "act": "@danger", "up": "@success", "down": "@danger", "meta": "#6B6E74" }
      }
    },
    "default_theme": "dark",
    "categorical": {
      "Venture": "#C878F0", "Product": "#E8B44C", "Quality": "#E8705F",
      "Speed": "#4D9FFF", "Trust": "#52C280", "Growth": "#A98CF5",
      "Team": "#3FC1C9", "Clarity": "#9AD4E8", "Design": "#5CE8A0",
      "Data": "#F0904A", "Ops": "#B4C64A", "Subtract": "#E87FB0",
      "Meta": "#C4CBD8", "Act": "#E84C3D", "Agent": "#8B7CF8",
      "Automation": "#E8DE5A", "AI-UX": "#F06FD8", "Compliance": "#8892B0",
      "API": "#2CB5C4", "Reliability": "#5FC08A", "AI-Ethics": "#6E8AF0",
      "Build": "#8CD94C"
    },
    "categorical_prefix": "f-",
    "categorical_var": "fc",
    "categorical_mix": { "light": { "toward": "black", "percent": 62 } },
    "notes": {
      "good": "Primary-action colour convention (HIERARCHY F6): amber / the family --fc is\n     the *browse/navigate* primary; --act (a distinct crimson) is the *commit /\n     act-adjacent* primary — the Studio Fixer button, the Act family. Deliberate,\n     not drift; kept distinct from every family hue (COLOR C2–C5).",
      "w-page": "container + rhythm scale (LAYOUT L1/T4 — one source; @media can't take var() so breakpoints stay literal)",
      "s1": "spacing scale — 4pt base (LAYOUT L2/L4/L6); map off-grid values (9,7,22…) onto it"
    }
  },
  "contrast": {
    "surfaces": ["ink", "ink-2", "panel", "panel-2"],
    "text_min": { "text": 4.5, "body": 4.5, "dim": 4.5, "faint": 3.0 },
    "accents": ["amber", "sev", "success", "warning", "danger", "fc", "meta"],
    "accents_min": 2.9,
    "categorical_min": 3.0,
    "categorical_surfaces": ["ink", "panel", "panel-2"],
    "note": "Seeded at the legacy floors so brand v1 passes exactly as shipped: accents_min 2.9 (light success 2.99 / warning 2.98 sit under the 3.0 non-text minimum) and categorical_surfaces excludes ink-2 (light Automation hits 2.97 on it), mirroring the surface set tests/test_build.py TokensTests has always pinned. The Phase-3 palette must clear 3.0 on ALL surfaces so both narrowings can be removed."
  },
  "type": {
    "faces": [
      {
        "role": "display",
        "family": "Schibsted Grotesk",
        "css_name": "Schib",
        "license": "OFL-1.1",
        "files": [
          { "path": "fonts/schibstedgrotesk-latin-var.woff2", "weight": "400 800", "style": "normal" }
        ]
      },
      {
        "role": "sans",
        "family": "IBM Plex Sans",
        "css_name": "PSans",
        "license": "OFL-1.1",
        "files": [
          { "path": "fonts/plexsans-latin-400.woff2", "weight": "400", "style": "normal" },
          { "path": "fonts/plexsans-latin-600.woff2", "weight": "600", "style": "normal" }
        ]
      },
      {
        "role": "mono",
        "family": "IBM Plex Mono",
        "css_name": "IBM Plex Mono",
        "license": "OFL-1.1",
        "files": [
          { "path": "fonts/plexmono-latin-400.woff2", "weight": "400", "style": "normal" },
          { "path": "fonts/plexmono-latin-600.woff2", "weight": "600", "style": "normal" }
        ]
      }
    ],
    "stacks": {
      "disp": "'Schib','PSans',system-ui,-apple-system,sans-serif",
      "sans": "'PSans',system-ui,-apple-system,'Segoe UI',Roboto,sans-serif",
      "mono": "'IBM Plex Mono',ui-monospace,'SF Mono',Menlo,Consolas,monospace"
    },
    "preload": [
      "fonts/schibstedgrotesk-latin-var.woff2",
      "fonts/plexsans-latin-400.woff2",
      "fonts/plexmono-latin-400.woff2"
    ]
  },
  "space": {
    "layout": { "w-page": "1120px", "w-doc": "960px", "w-read": "760px", "gutter": "24px", "lh-body": "1.6" },
    "scale": { "s1": "4px", "s2": "8px", "s3": "12px", "s4": "16px", "s5": "24px", "s6": "32px", "s7": "40px", "s8": "48px", "s9": "64px" },
    "sections": { "section": "64px", "section-tight": "48px" }
  },
  "radii": { "r-sm": "8px", "r-md": "12px", "r-pill": "999px", "radius": "8px" },
  "elevation": {
    "shadow-pop": "0 12px 40px -14px rgba(0,0,0,.75)",
    "shadow-pop-soft": "0 12px 40px -14px rgba(0,0,0,.55)"
  },
  "motion": {
    "durations": { "fast": "100ms", "base": "150ms", "slow": "200ms", "drift": "600ms" },
    "easings": {
      "standard": "cubic-bezier(.2,.6,.2,1)",
      "enter": "cubic-bezier(.16,.84,.3,1)",
      "exit": "cubic-bezier(.6,.1,.9,.4)",
      "spring": "cubic-bezier(.34,1.56,.64,1)"
    },
    "reduced_motion": "collapse-to-instant"
  },
  "mark": {
    "viewbox": 24,
    "rx": 1.7,
    "class": "mark",
    "size": 24,
    "bars": [
      { "x": 1, "y": 7, "w": 3.4, "h": 11, "color": "#E8B44C" },
      { "x": 6.9, "y": 3, "w": 3.4, "h": 18, "color": "#52C280" },
      { "x": 12.8, "y": 6, "w": 3.4, "h": 13, "color": "#4D9FFF" },
      { "x": 18.7, "y": 9, "w": 3.4, "h": 8, "color": "#C878F0" }
    ],
    "favicon": { "viewbox": 64, "bg": "#131417", "bg_radius": 13, "tx": 10, "ty": 9.2, "scale": 1.9 }
  },
  "host": {
    "integration": "python-import",
    "tokens_out": "tokens.css",
    "fonts_dir": "fonts",
    "fonts_url": "/fonts/",
    "pages_to_shoot": ["/", "/studio.html", "/vitals.html", "/b/01.html", "/p/facelift.html"],
    "themes_to_shoot": ["dark", "light"],
    "theme_storage_key": "gp-theme",
    "extra_css": [
      "button:active{transform:scale(.97)}",
      "button:disabled,[aria-disabled=\"true\"]{opacity:.5;cursor:not-allowed}"
    ],
    "hex_lint": {
      "files": ["template.html", "studio.html", "vitals.html"],
      "allow": []
    }
  }
}
